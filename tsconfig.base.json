{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": [
      "dom",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@startlang/lang-core": [
        "packages/lang-core/src/interpreter.ts"
      ],
      "@startlang/lang-core/*": [
        "packages/lang-core/src/*"
      ],
      "@startlang/lang-browser/*": [
        "packages/lang-browser/src/*"
      ]
    }
  }
}
